#!/bin/sh
set -e

# Fallback to 'nats' if NATS_HOST isn't passed to the environment
HOST="${NATS_HOST:-nats}"
MONITOR_URL="http://${HOST}:8222/healthz"
SERVER_URL="nats://${HOST}:4222"

echo "Checking health status for NATS at ${MONITOR_URL}..."

# Query the health endpoint until jq confirms status is "ok"
until [ "$(curl -s "$MONITOR_URL" | jq -r '.status')" = "ok" ]; do
  echo "Waiting for NATS server to report status OK..."
  sleep 2
done

echo "NATS engine healthy! Initializing components for {{ root }}..."

{% for key, value in get_context().items() %}
{% if value is mapping %}
echo "--- Configuring domain: {{ key }} ---"

{% if 'kv' in value %}
# 1. Create Key-Value Store (File Backed)
echo "Creating KV Store: {{ value.kv.bucket }}"
nats -s "$SERVER_URL" kv add {{ value.kv.bucket }} --storage file
{% endif %}

{% if 'stream' in value %}
# 2. Create Stream (File Backed)
echo "Creating Stream: {{ value.stream }}"
nats -s "$SERVER_URL" stream add {{ value.stream }} \
  --subjects "{% if 'subjects' in value %}{{ value.subjects | join(',') }}{% else %}{{ value.keyPrefix }}.>{% endif %}" \
  --defaults --storage file
{% endif %}

{% if 'objectStore' in value %}
# 3. Create Object Store (File Backed)
echo "Creating Object Store: {{ value.objectStore.bucket }}"
nats -s "$SERVER_URL" object add {{ value.objectStore.bucket }} --storage file
{% endif %}

echo ""
{% endif %}
{% endfor %}

echo "{{ root }} initialized!"